---
import { type Language, useTranslations, defaultLang } from '../i18n/translations';

interface Props {
  lang: Language;
}

const { lang } = Astro.props;
const t = useTranslations(lang);
---

<section class="relative py-24 md:py-40 overflow-hidden">
  <!-- Futuristic grid background -->
  <div class="absolute inset-0 opacity-[0.04] pointer-events-none"
    style="background-image: 
      linear-gradient(rgba(149,158,84,0.4) 1px, transparent 1px),
      linear-gradient(90deg, rgba(149,158,84,0.4) 1px, transparent 1px);
      background-size: 80px 80px;">
  </div>

  <!-- Animated gradient orbs -->
  <div class="absolute top-20 left-10 w-96 h-96 rounded-full 
    bg-gradient-to-br from-olive-500/20 to-olive-600/10 blur-[120px] animate-float"></div>
  <div class="absolute bottom-20 right-10 w-[500px] h-[500px] rounded-full 
    bg-gradient-to-br from-olive-400/15 to-olive-500/10 blur-[140px] animate-float" 
    style="animation-delay: 3s;"></div>
  <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2
    w-[600px] h-[600px] rounded-full bg-gradient-to-br from-olive-400/10 to-olive-300/5 blur-[160px] animate-pulse-slow"></div>

  <!-- Hexagon grid decoration -->
  <div class="absolute inset-0 opacity-[0.02] pointer-events-none"
    style="background-image: url('data:image/svg+xml,<svg xmlns=%22http://www.w3.org/2000/svg%22 width=%2260%22 height=%2270%22 viewBox=%220 0 60 70%22><path fill=%22none%22 stroke=%22%23959e54%22 stroke-width=%220.5%22 d=%22M30 5L55 20V50L30 65L5 50V20Z%22/></svg>');
    background-size: 60px 70px;">
  </div>

  <!-- Floating particles -->
  <div class="absolute inset-0 pointer-events-none overflow-hidden">
    <div class="absolute top-1/4 left-1/4 w-1 h-1 bg-olive-400/40 rounded-full animate-float" style="animation-delay: 1s;"></div>
    <div class="absolute top-1/3 right-1/3 w-1.5 h-1.5 bg-olive-300/30 rounded-full animate-float" style="animation-delay: 2s;"></div>
    <div class="absolute bottom-1/4 left-1/3 w-1 h-1 bg-olive-500/30 rounded-full animate-float" style="animation-delay: 4s;"></div>
    <div class="absolute top-2/3 right-1/4 w-0.5 h-0.5 bg-olive-400/40 rounded-full animate-float" style="animation-delay: 5s;"></div>
  </div>

  <div class="relative mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
    <div class="text-center">
      <!-- Glitch Badge -->
      <div class="mb-10 animate-[fadeIn_0.8s_ease-out]">
        <div class="inline-flex items-center gap-2 px-5 py-2.5 rounded-full
          bg-olive-500/10 backdrop-blur-sm border border-olive-500/20
          shadow-[0_0_20px_rgba(149,158,84,0.1)]">
          <span class="font-['Silkscreen'] text-sm text-olive-500 dark:text-olive-400 flex-shrink-0">>_</span>
          <span id="hero-greeting" class="font-['Silkscreen'] text-sm text-olive-600 dark:text-olive-300">developed by lare</span>
        </div>
      </div>

      <!-- Title -->
      <h1 class="font-black text-5xl sm:text-6xl md:text-7xl lg:text-[6rem] xl:text-[7rem]
        mb-10 leading-[0.9] animate-[slideUp_0.6s_ease-out_0.2s_both]">
        <span class="bg-gradient-to-r from-olive-700 dark:from-olive-200 via-olive-600 dark:via-olive-100 to-olive-500 dark:to-olive-300 
          bg-clip-text text-transparent">
          {t('hero.title')}
        </span>
      </h1>

      <!-- Subtitle with better typography -->
      <p class="max-w-3xl mx-auto text-lg sm:text-xl md:text-2xl lg:text-[1.65rem]
        text-light-text/60 dark:text-dark-text/60 
        font-light leading-relaxed mb-14 tracking-wide
        animate-[slideUp_0.6s_ease-out_0.4s_both]">
        {t('hero.subtitle')}
      </p>

      <!-- CTA Buttons with futuristic style -->
      <div class="flex flex-col sm:flex-row items-center justify-center gap-6
        animate-[slideUp_0.6s_ease-out_0.6s_both]">
        <a
          href="#ecosystem"
          class="group relative px-12 py-5 rounded-2xl overflow-hidden
            font-bold text-base uppercase tracking-[0.15em]
            transition-all duration-500 hover:scale-[1.03] hover:shadow-[0_0_50px_rgba(149,158,84,0.3)]"
        >
          <div class="absolute inset-0 bg-gradient-to-r from-olive-600 via-olive-500 to-olive-600 
            group-hover:from-olive-500 group-hover:via-olive-400 group-hover:to-olive-500 
            transition-all duration-500"></div>
          <div class="absolute inset-0 bg-gradient-to-r from-transparent via-white/20 to-transparent
            translate-x-[-200%] group-hover:translate-x-[200%] transition-transform duration-1000 ease-in-out"></div>
          <div class="absolute inset-0 rounded-2xl border border-olive-400/50 
            group-hover:border-olive-300/80 transition-colors duration-300
            shadow-[inset_0_1px_0_rgba(255,255,255,0.15),0_0_15px_rgba(149,158,84,0.2)]"></div>
          <span class="relative text-white flex items-center justify-center gap-3">
            {t('hero.cta')}
            <svg class="w-5 h-5 transform group-hover:translate-x-1.5 transition-transform duration-300" 
              fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6" />
            </svg>
          </span>
        </a>

        <a
          href="#pricing"
          class="group relative px-12 py-5 rounded-2xl overflow-hidden
            font-bold text-base uppercase tracking-[0.15em]
            transition-all duration-500 hover:scale-[1.03] hover:shadow-[0_0_30px_rgba(149,158,84,0.15)]"
        >
          <div class="absolute inset-0 bg-light-card/70 dark:bg-dark-card/70 backdrop-blur-xl"></div>
          <div class="absolute inset-0 rounded-2xl border-2 border-olive-500/30 
            group-hover:border-olive-400/60 transition-all duration-500
            shadow-[inset_0_1px_0_rgba(255,255,255,0.1),0_0_10px_rgba(149,158,84,0.1)]"></div>
          <div class="absolute inset-0 bg-gradient-to-r from-olive-500/0 to-olive-400/0
            group-hover:from-olive-500/10 group-hover:to-olive-400/10 transition-all duration-500"></div>
          <span class="relative text-olive-700 dark:text-olive-200 flex items-center justify-center gap-3">
            {t('hero.cta.pricing')}
            <svg class="w-5 h-5 transform group-hover:translate-x-1.5 transition-transform duration-300" 
              fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
            </svg>
          </span>
        </a>
      </div>

      <!-- Stats bar with glass morphism -->
      <div class="mt-24 flex flex-wrap items-center justify-center gap-10 md:gap-20
        animate-[fadeIn_0.8s_ease-out_0.8s_both]">
        <div class="text-center group">
          <div class="font-black text-4xl md:text-5xl bg-gradient-to-b from-olive-500 to-olive-700 dark:from-olive-300 dark:to-olive-500 
            bg-clip-text text-transparent group-hover:scale-110 transition-transform duration-300">4+</div>
          <div class="text-xs text-light-text/40 dark:text-dark-text/40 uppercase tracking-[0.25em] mt-2 font-medium">
            Tools
          </div>
        </div>
        <div class="w-px h-16 bg-gradient-to-b from-transparent via-olive-500/30 to-transparent hidden md:block"></div>
        <div class="text-center group">
          <div class="font-black text-4xl md:text-5xl bg-gradient-to-b from-olive-500 to-olive-700 dark:from-olive-300 dark:to-olive-500 
            bg-clip-text text-transparent group-hover:scale-110 transition-transform duration-300">100%</div>
          <div class="text-xs text-light-text/40 dark:text-dark-text/40 uppercase tracking-[0.25em] mt-2 font-medium">
            Premium
          </div>
        </div>
        <div class="w-px h-16 bg-gradient-to-b from-transparent via-olive-500/30 to-transparent hidden md:block"></div>
        <div class="text-center group">
          <div class="font-black text-4xl md:text-5xl bg-gradient-to-b from-olive-500 to-olive-700 dark:from-olive-300 dark:to-olive-500 
            bg-clip-text text-transparent group-hover:scale-110 transition-transform duration-300">24/7</div>
          <div class="text-xs text-light-text/40 dark:text-dark-text/40 uppercase tracking-[0.25em] mt-2 font-medium">
            Support
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- Scroll indicator with glass effect -->
  <div class="absolute bottom-12 left-1/2 -translate-x-1/2 animate-bounce-subtle">
    <div class="w-7 h-12 rounded-full border-2 border-olive-500/30 backdrop-blur-sm
      flex items-start justify-center p-2.5 shadow-[0_0_15px_rgba(149,158,84,0.2)]">
      <div class="w-1.5 h-3 rounded-full bg-gradient-to-b from-olive-400 to-olive-600 animate-pulse"></div>
    </div>
  </div>
</section>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const greetings = [
      "developed by lare",
      "sviluppato da lare",
      "由 lare 开发",
      "lare が開発",
      "desarrollado por lare"
    ];

    let currentGreeting = 0;
    const heroGreeting = document.getElementById('hero-greeting');
    const glitchChars = '!@#$%^&*()_+-=[]{}|;:,.<>?';

    function glitchEffect() {
      if (!heroGreeting) return;
      
      const original = heroGreeting.textContent || '';
      let iterations = 0;
      const maxIterations = 8;

      heroGreeting.classList.add('glitching');

      const interval = setInterval(() => {
        heroGreeting.textContent = original
          .split('')
          .map((char, i) => {
            if (i < iterations) return original[i];
            return glitchChars[Math.floor(Math.random() * glitchChars.length)];
          })
          .join('');

        iterations += 1;

        if (iterations > original.length) {
          clearInterval(interval);
          currentGreeting = (currentGreeting + 1) % greetings.length;
          heroGreeting.textContent = greetings[currentGreeting];
          heroGreeting.classList.remove('glitching');
        }
      }, 50);
    }

    setInterval(glitchEffect, 5000);
  });
</script>

<style>
  @import url('https://fonts.googleapis.com/css2?family=Silkscreen&display=swap');

  @keyframes glitch-skew {
    0%   { transform: skew(0deg); }
    20%  { transform: skew(-2deg); }
    40%  { transform: skew(1deg); }
    60%  { transform: skew(-1deg); }
    80%  { transform: skew(0.5deg); }
    100% { transform: skew(0deg); }
  }

  #hero-greeting {
    display: inline-block;
    min-width: 120px;
    text-align: center;
  }

  #hero-greeting.glitching {
    animation: glitch-skew 0.3s ease-in-out;
    text-shadow:
      2px 0 rgba(149, 158, 84, 0.6),
      -2px 0 rgba(149, 158, 84, 0.3);
  }
</style>
