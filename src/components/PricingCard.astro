---
import { type Language, useTranslations } from '../i18n/translations';

interface Props {
  lang: Language;
  nameKey: string;
  priceKey: string;
  descKey: string;
  featureKeys: string[];
  popular?: boolean;
  gradient: string;
  icon: string;
}

const { lang, nameKey, priceKey, descKey, featureKeys, popular = false, gradient, icon } = Astro.props;
const t = useTranslations(lang);
---

<div class:list={[
  'group relative',
  popular && 'md:-mt-4 md:mb-4',
]}>
  <!-- Popular badge -->
  {popular && (
    <div class="absolute -top-4 left-1/2 -translate-x-1/2 z-20">
      <div class="px-4 py-1.5 rounded-full bg-gradient-to-r from-olive-500 to-accent-gold
        font-bold text-xs uppercase tracking-wider text-white
        shadow-lg shadow-olive-500/30">
        {t('pricing.popular')}
      </div>
    </div>
  )}

  <!-- Card -->
  <div class:list={[
    'relative h-full rounded-2xl overflow-hidden',
    'border transition-all duration-500',
    'hover:shadow-2xl hover:shadow-olive-500/10',
    'transform hover:-translate-y-2',
    popular
      ? 'bg-light-card dark:bg-dark-card border-olive-500/50 shadow-xl shadow-olive-500/10'
      : 'bg-light-card/80 dark:bg-dark-card/80 backdrop-blur-sm border-light-border dark:border-dark-border hover:border-olive-500/30',
  ]}>
    <!-- Top gradient bar -->
    <div class:list={[
      'h-1 bg-gradient-to-r',
      gradient,
    ]}></div>

    <!-- Background decoration -->
    <div class="absolute top-0 right-0 w-64 h-64 opacity-5 group-hover:opacity-10 transition-opacity duration-500">
      <svg viewBox="0 0 200 200" fill="none" class="w-full h-full">
        <circle cx="150" cy="50" r="120" stroke="currentColor" stroke-width="0.5" class="text-olive-500" />
        <circle cx="150" cy="50" r="80" stroke="currentColor" stroke-width="0.5" class="text-olive-500" />
      </svg>
    </div>

    <div class="relative z-10 p-8 md:p-10">
      <!-- Header -->
      <div class="text-center mb-8">
        <!-- Icon -->
        <div class:list={[
          'w-16 h-16 mx-auto rounded-2xl flex items-center justify-center mb-6',
          'bg-gradient-to-br shadow-xl',
          gradient,
          'shadow-olive-500/20',
          'transform group-hover:scale-110 transition-transform duration-300',
        ]}>
          <div class="text-white" set:html={icon} />
        </div>

        <!-- Name -->
        <h3 class="font-bold text-xl mb-2 text-light-text dark:text-dark-text">
          {t(nameKey)}
        </h3>

        <!-- Price -->
        <div class="flex items-baseline justify-center gap-2 mb-4">
          <span class="font-black text-5xl 
            bg-gradient-to-r from-olive-700 dark:from-olive-300 to-olive-900 dark:to-olive-100 
            bg-clip-text text-transparent">
            {t(priceKey)}
          </span>
        </div>

        <!-- Badge -->
        <div class="inline-flex items-center gap-2 px-3 py-1.5 rounded-full
          bg-olive-500/10 border border-olive-500/20">
          <svg class="w-3.5 h-3.5 text-olive-500" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
          </svg>
          <span class="font-medium text-xs uppercase tracking-wider 
            text-olive-600 dark:text-olive-400">
            {t('pricing.one.time')}
          </span>
        </div>
      </div>

      <!-- Description -->
      <p class="text-center text-light-text/60 dark:text-dark-text/60 text-sm leading-relaxed mb-8">
        {t(descKey)}
      </p>

      <!-- Divider -->
      <div class="h-px bg-gradient-to-r from-transparent via-light-border dark:via-dark-border to-transparent mb-8"></div>

      <!-- Features -->
      <ul class="space-y-4 mb-10">
        {featureKeys.map((key) => (
          <li class="flex items-center gap-3">
            <div class="w-5 h-5 rounded-full bg-olive-500/10 flex items-center justify-center flex-shrink-0">
              <svg class="w-3 h-3 text-olive-500" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M5 13l4 4L19 7" />
              </svg>
            </div>
            <span class="text-sm text-light-text/70 dark:text-dark-text/70">
              {t(key)}
            </span>
          </li>
        ))}
        <li class="flex items-center gap-3">
          <div class="w-5 h-5 rounded-full bg-olive-500/10 flex items-center justify-center flex-shrink-0">
            <svg class="w-3 h-3 text-olive-500" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M5 13l4 4L19 7" />
            </svg>
          </div>
          <span class="text-sm text-light-text/70 dark:text-dark-text/70">
            {t('pricing.lifetime')}
          </span>
        </li>
        <li class="flex items-center gap-3">
          <div class="w-5 h-5 rounded-full bg-olive-500/10 flex items-center justify-center flex-shrink-0">
            <svg class="w-3 h-3 text-olive-500" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M5 13l4 4L19 7" />
            </svg>
          </div>
          <span class="text-sm text-light-text/70 dark:text-dark-text/70">
            {t('pricing.no.sub')}
          </span>
        </li>
      </ul>

      <!-- CTA Button -->
      <a
        href="#"
        class:list={[
          'group/btn relative block w-full py-4 rounded-xl overflow-hidden',
          'font-bold text-sm uppercase tracking-wider',
          'text-center transition-all duration-300 hover:scale-[1.02]',
          popular
            ? 'bg-gradient-to-r from-olive-600 to-olive-500 hover:from-olive-500 hover:to-olive-400 text-white shadow-lg shadow-olive-500/30'
            : 'bg-olive-500/10 border-2 border-olive-500/30 hover:border-olive-500/60 text-olive-700 dark:text-olive-300',
        ]}
      >
        {popular && (
          <div class="absolute inset-0 bg-gradient-to-r from-transparent via-white/20 to-transparent
            translate-x-[-200%] group-hover/btn:translate-x-[200%] transition-transform duration-700"></div>
        )}
        <span class="relative flex items-center justify-center gap-2">
          {t('pricing.get.access')}
          <svg class="w-4 h-4 transform group-hover/btn:translate-x-1 transition-transform duration-300" 
            fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6" />
          </svg>
        </span>
      </a>
    </div>
  </div>
</div>
