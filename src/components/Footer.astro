---
import { type Language, useTranslations, defaultLang } from '../i18n/translations';

interface Props {
  lang: Language;
}

const { lang } = Astro.props;
const t = useTranslations(lang);

const langPrefix = lang === defaultLang ? '' : `/${lang}`;

const ecosystemLinks = [
  { href: 'https://clare-web-ivory.vercel.app/', label: '[c] Confesiones' },
  { href: 'https://laredev.vercel.app/', label: '[p] Portfolio' },
  { href: 'https://lareditor.vercel.app/', label: '[v] Video Editor' },
];

const socialLinks = [
  { href: 'https://github.com/Larevalot', label: 'GitHub', icon: 'github' },
  { href: 'https://www.instagram.com/larevalot_/', label: 'Instagram', icon: 'instagram' },
  { href: 'https://x.com/larevalot_', label: 'X', icon: 'x' },
  { href: 'https://discord.gg/ab2XNv7qYA', label: 'Discord', icon: 'discord' },
];
---

<footer class="relative mt-40">
  <!-- Top gradient border with glow -->
  <div class="relative">
    <div class="h-px bg-gradient-to-r from-transparent via-olive-500/50 to-transparent"></div>
    <div class="absolute top-0 left-1/2 -translate-x-1/2 w-48 h-24 bg-olive-500/10 blur-[60px] rounded-full"></div>
  </div>

  <div class="relative bg-gradient-to-b from-transparent to-olive-500/5">
    <!-- Background grid -->
    <div class="absolute inset-0 opacity-[0.02] pointer-events-none"
      style="background-image: 
        linear-gradient(rgba(149,158,84,0.3) 1px, transparent 1px),
        linear-gradient(90deg, rgba(149,158,84,0.3) 1px, transparent 1px);
        background-size: 60px 60px;">
    </div>

    <div class="relative mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 py-20">
      <div class="grid grid-cols-1 md:grid-cols-4 gap-14">

        <!-- Brand -->
        <div class="md:col-span-1">
          <a href={`/${lang === defaultLang ? '' : lang}`} class="flex items-center gap-3 mb-8 group">
            <span class="font-bold text-lg tracking-[0.15em]
              bg-gradient-to-r from-olive-600 dark:from-olive-200 via-olive-500 dark:via-olive-100 to-olive-400 dark:to-olive-300 
              bg-clip-text text-transparent group-hover:from-olive-500 dark:group-hover:from-olive-300 group-hover:to-olive-300 dark:group-hover:to-olive-200
              transition-all duration-500">
              [studio] larevalot
            </span>
          </a>
          <p class="text-sm text-light-text/50 dark:text-dark-text/50 leading-relaxed font-light">
            {t('hero.subtitle').substring(0, 100)}...
          </p>
        </div>

        <!-- Ecosystem Links -->
        <div>
          <h3 class="font-bold text-sm uppercase tracking-[0.15em] 
            text-olive-600 dark:text-olive-300 mb-8">
            {t('footer.ecosystem')}
          </h3>
          <ul class="space-y-4">
            {ecosystemLinks.map((link) => (
              <li>
                <a
                  href={link.href}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="text-sm text-light-text/50 dark:text-dark-text/50 
                    hover:text-olive-600 dark:hover:text-olive-300 
                    transition-all duration-500 flex items-center gap-3 group"
                >
                  <span class="w-1.5 h-1.5 rounded-full bg-olive-500/40 group-hover:bg-olive-400 group-hover:shadow-[0_0_6px_rgba(149,158,84,0.6)] transition-all duration-300"></span>
                  {link.label}
                </a>
              </li>
            ))}
          </ul>
        </div>

        <!-- Resources -->
        <div>
          <h3 class="font-bold text-sm uppercase tracking-[0.15em] 
            text-olive-600 dark:text-olive-300 mb-8">
            {t('footer.resources')}
          </h3>
          <ul class="space-y-4">
            <li>
              <a href={`${langPrefix}/docs`} class="text-sm text-light-text/50 dark:text-dark-text/50 
                hover:text-olive-600 dark:hover:text-olive-300 
                transition-all duration-500 flex items-center gap-3 group">
                <span class="w-1.5 h-1.5 rounded-full bg-olive-500/40 group-hover:bg-olive-400 group-hover:shadow-[0_0_6px_rgba(149,158,84,0.6)] transition-all duration-300"></span>
                {t('footer.docs')}
              </a>
            </li>
            <li>
              <a href="#" class="text-sm text-light-text/50 dark:text-dark-text/50 
                hover:text-olive-600 dark:hover:text-olive-300 
                transition-all duration-500 flex items-center gap-3 group">
                <span class="w-1.5 h-1.5 rounded-full bg-olive-500/40 group-hover:bg-olive-400 group-hover:shadow-[0_0_6px_rgba(149,158,84,0.6)] transition-all duration-300"></span>
                {t('footer.support')}
              </a>
            </li>
          </ul>
        </div>

        <!-- Legal -->
        <div>
          <h3 class="font-bold text-sm uppercase tracking-[0.15em] 
            text-olive-600 dark:text-olive-300 mb-8">
            {t('footer.legal')}
          </h3>
          <ul class="space-y-4">
            <li>
              <a href={`${langPrefix}/privacy`} class="text-sm text-light-text/50 dark:text-dark-text/50 
                hover:text-olive-600 dark:hover:text-olive-300 
                transition-all duration-500 flex items-center gap-3 group">
                <span class="w-1.5 h-1.5 rounded-full bg-olive-500/40 group-hover:bg-olive-400 group-hover:shadow-[0_0_6px_rgba(149,158,84,0.6)] transition-all duration-300"></span>
                {t('footer.privacy')}
              </a>
            </li>
            <li>
              <a href={`${langPrefix}/terms`} class="text-sm text-light-text/50 dark:text-dark-text/50 
                hover:text-olive-600 dark:hover:text-olive-300 
                transition-all duration-500 flex items-center gap-3 group">
                <span class="w-1.5 h-1.5 rounded-full bg-olive-500/40 group-hover:bg-olive-400 group-hover:shadow-[0_0_6px_rgba(149,158,84,0.6)] transition-all duration-300"></span>
                {t('footer.terms')}
              </a>
            </li>
          </ul>
        </div>
      </div>

      <!-- Social Links -->
      <div class="mt-16 flex justify-center gap-6">
        {socialLinks.map((social) => (
          <a
            href={social.href}
            target="_blank"
            rel="noopener noreferrer"
            class="w-12 h-12 rounded-xl bg-light-card/40 dark:bg-dark-card/40 backdrop-blur-xl
              border border-light-border/30 dark:border-dark-border/30
              hover:border-olive-500/40 hover:shadow-[0_0_15px_rgba(149,158,84,0.15)]
              transition-all duration-500 flex items-center justify-center group"
            aria-label={social.label}
          >
            {social.icon === 'github' && (
              <svg class="w-5 h-5 text-light-text/50 dark:text-dark-text/50 group-hover:text-olive-500 dark:group-hover:text-olive-400 transition-colors duration-300" fill="currentColor" viewBox="0 0 24 24">
                <path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/>
              </svg>
            )}
            {social.icon === 'instagram' && (
              <svg class="w-5 h-5 text-light-text/50 dark:text-dark-text/50 group-hover:text-olive-500 dark:group-hover:text-olive-400 transition-colors duration-300" fill="currentColor" viewBox="0 0 24 24">
                <path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z"/>
              </svg>
            )}
            {social.icon === 'x' && (
              <svg class="w-5 h-5 text-light-text/50 dark:text-dark-text/50 group-hover:text-olive-500 dark:group-hover:text-olive-400 transition-colors duration-300" fill="currentColor" viewBox="0 0 24 24">
                <path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/>
              </svg>
            )}
            {social.icon === 'discord' && (
              <svg class="w-5 h-5 text-light-text/50 dark:text-dark-text/50 group-hover:text-olive-500 dark:group-hover:text-olive-400 transition-colors duration-300" fill="currentColor" viewBox="0 0 24 24">
                <path d="M20.317 4.3698a19.7913 19.7913 0 00-4.8851-1.5152.0741.0741 0 00-.0785.0371c-.211.3753-.4447.8648-.6083 1.2495-1.8447-.2762-3.68-.2762-5.4868 0-.1636-.3933-.4058-.8742-.6177-1.2495a.077.077 0 00-.0785-.037 19.7363 19.7363 0 00-4.8852 1.515.0699.0699 0 00-.0321.0277C.5334 9.0458-.319 13.5799.0992 18.0578a.0824.0824 0 00.0312.0561c2.0528 1.5076 4.0413 2.4228 5.9929 3.0294a.0777.0777 0 00.0842-.0276c.4616-.6304.8731-1.2952 1.226-1.9942a.076.076 0 00-.0416-.1057c-.6528-.2476-1.2743-.5495-1.8722-.8923a.077.077 0 01-.0076-.1277c.1258-.0943.2517-.1923.3718-.2914a.0743.0743 0 01.0776-.0105c3.9278 1.7933 8.18 1.7933 12.0614 0a.0739.0739 0 01.0785.0095c.1202.099.246.1981.3728.2924a.077.077 0 01-.0066.1276 12.2986 12.2986 0 01-1.873.8914.0766.0766 0 00-.0407.1067c.3604.698.7719 1.3628 1.225 1.9932a.076.076 0 00.0842.0286c1.961-.6067 3.9495-1.5219 6.0023-3.0294a.077.077 0 00.0313-.0552c.5004-5.177-.8382-9.6739-3.5485-13.6604a.061.061 0 00-.0312-.0286zM8.02 15.3312c-1.1825 0-2.1569-1.0857-2.1569-2.419 0-1.3332.9555-2.4189 2.157-2.4189 1.2108 0 2.1757 1.0952 2.1568 2.419 0 1.3332-.9555 2.4189-2.1569 2.4189zm7.9748 0c-1.1825 0-2.1569-1.0857-2.1569-2.419 0-1.3332.9554-2.4189 2.1569-2.4189 1.2108 0 2.1757 1.0952 2.1568 2.419 0 1.3332-.946 2.4189-2.1568 2.4189z"/>
              </svg>
            )}
          </a>
        ))}
      </div>

      <!-- Bottom bar -->
      <div class="mt-20 pt-10 border-t border-light-border/20 dark:border-dark-border/20">
        <div class="flex flex-col md:flex-row justify-between items-center gap-6">
          <p class="text-sm text-light-text/30 dark:text-dark-text/30 font-light tracking-wide">
            {t('footer.rights')}
          </p>
          <div class="flex items-center gap-8">
            <!-- Decorative animated dots -->
            <div class="flex items-center gap-2.5">
              <div class="w-2 h-2 rounded-full bg-olive-500/30 animate-pulse shadow-[0_0_4px_rgba(149,158,84,0.3)]"></div>
              <div class="w-2 h-2 rounded-full bg-olive-500/20 animate-pulse shadow-[0_0_4px_rgba(149,158,84,0.2)]" style="animation-delay: 0.5s;"></div>
              <div class="w-2 h-2 rounded-full bg-olive-500/10 animate-pulse shadow-[0_0_4px_rgba(149,158,84,0.1)]" style="animation-delay: 1s;"></div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</footer>
