---
import Layout from '../layouts/Layout.astro';
import PricingCard from '../components/PricingCard.astro';
import { defaultLang, type Language, useTranslations } from '../i18n/translations';

const lang = defaultLang as Language;
const t = useTranslations(lang);

const pricingProducts = [
  {
    nameKey: 'pricing.lareditor.v.name',
    priceKey: 'pricing.lareditor.v.price',
    descKey: 'pricing.lareditor.v.desc',
    featureKeys: [
      'pricing.lareditor.v.feature.1',
      'pricing.lareditor.v.feature.2',
      'pricing.lareditor.v.feature.3',
      'pricing.lareditor.v.feature.4',
    ],
    popular: true,
    gradient: 'from-olive-500 to-emerald-500',
    icon: `<svg class="w-8 h-8" fill="none" viewBox="0 0 24 24" stroke="currentColor">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M11 4H4a2 2 0 00-2 2v14a2 2 0 002 2h14a2 2 0 002-2v-7" />
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M18.5 2.5a2.121 2.121 0 013 3L12 15l-4 1 1-4 9.5-9.5z" />
    </svg>`,
  },
  {
    nameKey: 'pricing.lareditor.img.name',
    priceKey: 'pricing.lareditor.img.price',
    descKey: 'pricing.lareditor.img.desc',
    featureKeys: [
      'pricing.lareditor.img.feature.1',
      'pricing.lareditor.img.feature.2',
      'pricing.lareditor.img.feature.3',
      'pricing.lareditor.img.feature.4',
    ],
    popular: false,
    gradient: 'from-accent-gold to-olive-500',
    icon: `<svg class="w-8 h-8" fill="none" viewBox="0 0 24 24" stroke="currentColor">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z" />
    </svg>`,
  },
];
---

<Layout title="Pricing - [studio] larevalot" lang={lang}>
  <section class="relative py-20 md:py-32">
    <!-- Background decorations -->
    <div class="absolute top-20 left-10 w-96 h-96 rounded-full 
      bg-olive-500/10 blur-[120px] animate-float"></div>
    <div class="absolute bottom-20 right-10 w-80 h-80 rounded-full 
      bg-accent-gold/10 blur-[100px] animate-float" 
      style="animation-delay: 3s;"></div>

    <div class="relative mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <!-- Header -->
      <div class="text-center mb-16 md:mb-24">
        <div class="inline-flex items-center gap-2 px-4 py-2 rounded-full mb-6
          bg-olive-500/10 border border-olive-500/20">
          <div class="w-2 h-2 rounded-full bg-accent-gold animate-pulse"></div>
          <span class="font-medium text-sm uppercase tracking-wider 
            text-olive-600 dark:text-olive-400">
            {t('pricing.badge')}
          </span>
        </div>

        <h1 class="font-black text-4xl sm:text-5xl md:text-6xl mb-6">
          <span class="relative inline-block">
            <span class="absolute inset-0 blur-3xl bg-gradient-to-r from-olive-500/20 to-accent-gold/20"></span>
            <span class="relative bg-gradient-to-r from-olive-700 dark:from-olive-300 to-accent-gold 
              bg-clip-text text-transparent">
              {t('pricing.title')}
            </span>
          </span>
        </h1>

        <p class="max-w-3xl mx-auto text-lg sm:text-xl 
          text-light-text/70 dark:text-dark-text/70 
          font-light leading-relaxed">
          {t('pricing.subtitle')}
        </p>
      </div>

      <!-- Pricing cards -->
      <div class="grid grid-cols-1 md:grid-cols-2 gap-8 lg:gap-12 max-w-4xl mx-auto">
        {pricingProducts.map((product) => (
          <PricingCard
            lang={lang}
            nameKey={product.nameKey}
            priceKey={product.priceKey}
            descKey={product.descKey}
            featureKeys={product.featureKeys}
            popular={product.popular}
            gradient={product.gradient}
            icon={product.icon}
          />
        ))}
      </div>

      <!-- Trust badges -->
      <div class="mt-20 text-center">
        <div class="inline-flex flex-wrap items-center justify-center gap-8 
          px-8 py-6 rounded-2xl
          bg-light-card/50 dark:bg-dark-card/50 backdrop-blur-sm
          border border-light-border/50 dark:border-dark-border/50">
          <div class="flex items-center gap-3">
            <svg class="w-6 h-6 text-olive-500" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" />
            </svg>
            <span class="font-medium text-sm text-light-text/70 dark:text-dark-text/70">
              Secure Payment
            </span>
          </div>
          <div class="w-px h-8 bg-light-border dark:bg-dark-border hidden sm:block"></div>
          <div class="flex items-center gap-3">
            <svg class="w-6 h-6 text-olive-500" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
            </svg>
            <span class="font-medium text-sm text-light-text/70 dark:text-dark-text/70">
              Lifetime Access
            </span>
          </div>
          <div class="w-px h-8 bg-light-border dark:bg-dark-border hidden sm:block"></div>
          <div class="flex items-center gap-3">
            <svg class="w-6 h-6 text-olive-500" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15" />
            </svg>
            <span class="font-medium text-sm text-light-text/70 dark:text-dark-text/70">
              Free Updates
            </span>
          </div>
        </div>
      </div>
    </div>
  </section>
</Layout>
