---
import Layout from '../../layouts/Layout.astro';
import { type Language } from '../../i18n/translations';

const lang = 'it' as Language;
---

<Layout title="Documentazione - [studio] larevalot" lang={lang}>
  <section class="relative py-24 md:py-36 overflow-hidden">
    <div class="absolute top-0 left-0 right-0 h-px bg-gradient-to-r from-transparent via-olive-500/40 to-transparent"></div>
    <div class="absolute inset-0 pointer-events-none overflow-hidden">
      <div class="absolute top-1/4 left-1/4 w-[400px] h-[400px] rounded-full bg-gradient-to-br from-olive-500/6 to-olive-400/3 blur-[100px] animate-float"></div>
    </div>
    <div class="mx-auto max-w-4xl px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-16">
        <svg class="w-16 h-16 mx-auto mb-6 text-olive-500 dark:text-olive-400" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253" /></svg>
        <h1 class="font-black text-4xl sm:text-5xl md:text-6xl mb-6"><span class="bg-gradient-to-r from-olive-700 dark:from-olive-200 via-olive-600 dark:via-olive-100 to-olive-500 dark:to-olive-300 bg-clip-text text-transparent">Documentazione</span></h1>
        <p class="text-light-text/60 dark:text-dark-text-600 font-light">Impara a usare i nostri strumenti in modo efficace</p>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
        <div class="group p-8 rounded-2xl bg-light-card/60 dark:bg-dark-card/60 backdrop-blur-xl border border-light-border/30 dark:border-dark-border/30 hover:border-olive-500/40 transition-all duration-500">
          <div class="w-14 h-14 rounded-xl bg-gradient-to-br from-olive-500 to-olive-600 flex items-center justify-center mb-6 shadow-lg shadow-olive-500/25"><svg class="w-7 h-7 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M15 10l4.553-2.276A1 1 0 0121 8.618v6.764a1 1 0 01-1.447.894L15 14M5 18h8a2 2 0 002-2V8a2 2 0 00-2-2H5a2 2 0 00-2 2v8a2 2 0 002 2z" /></svg></div>
          <h3 class="font-bold text-xl text-light-text dark:text-dark-text mb-3">Editor Video</h3>
          <p class="text-light-text/60 dark:text-dark-text/60 mb-4">Impara a creare e modificare video con il nostro editor intuitivo.</p>
          <ul class="space-y-2 text-sm text-light-text/50 dark:text-dark-text/50"><li class="flex items-center gap-2"><svg class="w-4 h-4 text-olive-500" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" /></svg>Guida introduttiva</li><li class="flex items-center gap-2"><svg class="w-4 h-4 text-olive-500" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" /></svg>Strumenti di editing</li></ul>
        </div>
        <div class="group p-8 rounded-2xl bg-light-card/60 dark:bg-dark-card/60 backdrop-blur-xl border border-light-border/30 dark:border-dark-border/30 hover:border-olive-500/40 transition-all duration-500">
          <div class="w-14 h-14 rounded-xl bg-gradient-to-br from-olive-400 to-olive-500 flex items-center justify-center mb-6 shadow-lg shadow-olive-500/25"><svg class="w-7 h-7 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z" /></svg></div>
          <h3 class="font-bold text-xl text-light-text dark:text-dark-text mb-3">Editor Immagini</h3>
          <p class="text-light-text/60 dark:text-dark-text/60 mb-4">Padroneggia i nostri strumenti di editing immagini con IA.</p>
          <ul class="space-y-2 text-sm text-light-text/50 dark:text-dark-text/50"><li class="flex items-center gap-2"><svg class="w-4 h-4 text-olive-500" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" /></svg>Guida alle funzioni IA</li><li class="flex items-center gap-2"><svg class="w-4 h-4 text-olive-500" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" /></svg>Filtri ed effetti</li></ul>
        </div>
      </div>
    </div>
  </section>
</Layout>
