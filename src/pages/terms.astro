---
import Layout from '../layouts/Layout.astro';
import { type Language } from '../i18n/translations';

const lang = 'en' as Language;
---

<Layout title="Terms of Service - [studio] larevalot" lang={lang}>
  <section class="relative py-24 md:py-36 overflow-hidden">
    <div class="absolute top-0 left-0 right-0 h-px bg-gradient-to-r from-transparent via-olive-500/40 to-transparent"></div>
    
    <div class="absolute inset-0 pointer-events-none overflow-hidden">
      <div class="absolute top-1/4 left-1/4 w-[400px] h-[400px] rounded-full 
        bg-gradient-to-br from-olive-500/6 to-olive-400/3 blur-[100px] animate-float"></div>
    </div>

    <div class="mx-auto max-w-4xl px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-16">
        <svg class="w-16 h-16 mx-auto mb-6 text-olive-500 dark:text-olive-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
        </svg>
        <h1 class="font-black text-4xl sm:text-5xl md:text-6xl mb-6">
          <span class="bg-gradient-to-r from-olive-700 dark:from-olive-200 via-olive-600 dark:via-olive-100 to-olive-500 dark:to-olive-300 
            bg-clip-text text-transparent">
            Terms of Service
          </span>
        </h1>
        <p class="text-light-text/60 dark:text-dark-text-600 font-light">Last updated: January 2025</p>
      </div>

      <div class="prose prose-lg max-w-none">
        <div class="p-8 rounded-2xl bg-light-card/60 dark:bg-dark-card/60 backdrop-blur-xl border border-light-border/30 dark:border-dark-border/30 mb-8">
          <h2 class="font-bold text-2xl text-light-text dark:text-dark-text mb-4">1. Acceptance of Terms</h2>
          <p class="text-light-text/70 dark:text-dark-text/70 leading-relaxed">
            By accessing and using [studio] larevalot tools and services, you accept and agree to be bound by the terms and provision of this agreement.
          </p>
        </div>

        <div class="p-8 rounded-2xl bg-light-card/60 dark:bg-dark-card/60 backdrop-blur-xl border border-light-border/30 dark:border-dark-border/30 mb-8">
          <h2 class="font-bold text-2xl text-light-text dark:text-dark-text mb-4">2. Use License</h2>
          <p class="text-light-text/70 dark:text-dark-text/70 leading-relaxed mb-4">
            Permission is granted to use our tools for personal and commercial purposes. This is the grant of a license, not a transfer of title.
          </p>
          <ul class="list-disc list-inside space-y-2 text-light-text/70 dark:text-dark-text/70">
            <li>You may not modify or copy the materials</li>
            <li>You may not use the materials for commercial purposes without proper license</li>
            <li>You may not attempt to reverse engineer any software</li>
          </ul>
        </div>

        <div class="p-8 rounded-2xl bg-light-card/60 dark:bg-dark-card/60 backdrop-blur-xl border border-light-border/30 dark:border-dark-border/30 mb-8">
          <h2 class="font-bold text-2xl text-light-text dark:text-dark-text mb-4">3. Payment Terms</h2>
          <p class="text-light-text/70 dark:text-dark-text/70 leading-relaxed">
            All payments are processed securely. One-time payments grant lifetime access to the purchased tools. Refunds are available within 30 days of purchase.
          </p>
        </div>

        <div class="p-8 rounded-2xl bg-light-card/60 dark:bg-dark-card/60 backdrop-blur-xl border border-light-border/30 dark:border-dark-border/30 mb-8">
          <h2 class="font-bold text-2xl text-light-text dark:text-dark-text mb-4">4. Contact</h2>
          <p class="text-light-text/70 dark:text-dark-text/70 leading-relaxed">
            For questions about these Terms, please contact us through our support channels.
          </p>
        </div>
      </div>
    </div>
  </section>
</Layout>
